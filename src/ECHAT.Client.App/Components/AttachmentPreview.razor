@using ECHAT.Client.App.Services
@using ECHAT.Models.Domain
@implements IAsyncDisposable
@inject ChatSdkService ChatSdk
@inject IJSRuntime JS

@if (_state == State.Pending)
{
    <div class="att-card" style="@CardStyle">
        <span class="att-icon">@TypeIcon</span>
        <div class="att-meta">
            <div class="att-name">@Attachment.FileName</div>
            <div class="att-sub">@Attachment.MimeType · @FormatSize(Attachment.Size)</div>
        </div>
        <button class="btn btn-sm btn-outline-primary" @onclick="LoadAsync">Preview</button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadAsync">Download</button>
    </div>
}
else if (_state == State.Loading)
{
    <div class="att-card" style="@CardStyle">
        <span class="att-icon">⏳</span>
        <div class="att-meta">
            <div class="att-name">@Attachment.FileName</div>
            <div class="att-sub">Decrypting @FormatSize(Attachment.Size)…</div>
        </div>
    </div>
}
else if (_state == State.Error)
{
    <div class="att-card att-error" style="@CardStyle">
        <span class="att-icon">⚠</span>
        <div class="att-meta">
            <div class="att-name">@Attachment.FileName</div>
            <div class="att-sub" style="color:#e01e5a">@_error</div>
        </div>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">Retry</button>
    </div>
}
else if (_state == State.Loaded)
{
    @if (IsImage)
    {
        <div class="att-frame" style="@CardStyle">
            <img src="@_blobUrl" alt="@Attachment.FileName"
                 style="max-width:100%; max-height:560px; border-radius:6px; display:block;" />
            <div class="att-sub" style="margin-top:4px;">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size)</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else if (IsVideo)
    {
        <div class="att-frame" style="@CardStyle">
            <video src="@_blobUrl" controls preload="metadata"
                   style="max-width:100%; max-height:560px; border-radius:6px; display:block;"></video>
            <div class="att-sub">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size)</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else if (IsAudio)
    {
        <div class="att-frame" style="@CardStyle">
            <audio src="@_blobUrl" controls style="width:100%;"></audio>
            <div class="att-sub">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size)</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else if (IsCsv && _csvRows is not null)
    {
        <div class="att-frame" style="@CardStyle">
            <div style="overflow-x:auto; max-height:480px; border:1px solid #e0e0e0; border-radius:6px;">
                <table style="border-collapse:collapse; font-size:0.85em; width:100%;">
                    @if (_csvRows.Count > 0)
                    {
                        <thead style="background:#f5f5f5; position:sticky; top:0;">
                            <tr>
                                @foreach (var cell in _csvRows[0])
                                {
                                    <th style="padding:4px 8px; border:1px solid #e0e0e0; text-align:left;">@cell</th>
                                }
                            </tr>
                        </thead>
                    }
                    <tbody>
                        @for (int r = 1; r < _csvRows.Count; r++)
                        {
                            <tr>
                                @foreach (var cell in _csvRows[r])
                                {
                                    <td style="padding:3px 8px; border:1px solid #efefef;">@cell</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="att-sub">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size) · @(_csvRows.Count) rows shown</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else if (IsPdf)
    {
        <div class="att-frame" style="@CardStyle">
            <iframe src="@_blobUrl" title="@Attachment.FileName"
                    style="width:100%; height:720px; border-radius:6px; border:1px solid #e0e0e0;"></iframe>
            <div class="att-sub">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size)</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else if (IsHtml)
    {
        <div class="att-frame" style="@CardStyle">
            <div style="background:#fff8db; border:1px solid #f0e7a0; border-radius:6px 6px 0 0; padding:4px 10px; font-size:0.78em; color:#55471d;">
                🛡 Sandboxed preview of <strong>@Attachment.FileName</strong>. Scripts, forms and top-level navigation are blocked.
            </div>
            @* sandbox=""  massima restrizione: niente script, niente form, niente popup, trattato
               come origin unica così il documento non può toccare cookie/storage/DOM del parent. L'URL
               blob: tiene il documento fuori dalla rete; le subresource passano comunque dalla CSP del parent. *@
            <iframe src="@_blobUrl" title="@Attachment.FileName" sandbox=""
                    referrerpolicy="no-referrer"
                    style="width:100%; height:560px; border:1px solid #e0e0e0; border-top:none; border-radius:0 0 6px 6px; background:white;"></iframe>
            <div class="att-sub">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size)</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else if (IsPlainText)
    {
        <div class="att-frame" style="@CardStyle">
            <pre style="background:#f8f8f8; border:1px solid #e0e0e0; border-radius:6px; padding:8px; max-height:300px; overflow:auto; font-size:0.82em;">@_textPreview</pre>
            <div class="att-sub">
                <span>@Attachment.FileName · @FormatSize(Attachment.Size)</span>
                <button class="btn btn-sm btn-link" style="padding:0; margin-left:8px;" @onclick="DownloadAsync">Download</button>
            </div>
        </div>
    }
    else
    {
        <div class="att-card" style="@CardStyle">
            <span class="att-icon">@TypeIcon</span>
            <div class="att-meta">
                <div class="att-name">@Attachment.FileName</div>
                <div class="att-sub">@Attachment.MimeType · @FormatSize(Attachment.Size) · preview not supported</div>
            </div>
            <button class="btn btn-sm btn-primary" @onclick="DownloadAsync">Download</button>
        </div>
    }
}

<style>
    .att-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px 12px;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        background: #fafafa;
        cursor: pointer;
        text-align: left;
        max-width: 460px;
    }
    .att-card:hover { background: #f0f0f0; }
    .att-error { background: #fdf3f5; }
    .att-icon { font-size: 1.4em; }
    .att-meta { flex: 1; min-width: 0; }
    .att-name { font-weight: 600; word-break: break-all; }
    .att-sub { font-size: 0.78em; color: #666; }
    .att-action { font-size: 0.85em; color: #1264a3; }
    /* Le preview si allargano per riempire la colonna del messaggio. Gli elementi inline
       (img/video/iframe) mantengono la loro max-height così un PDF o video alto non spinge
       il messaggio successivo troppo in basso. */
    .att-frame { width: 100%; margin-top: 4px; }
</style>

@code {
    [Parameter, EditorRequired] public AttachmentRef Attachment { get; set; } = default!;
    [Parameter, EditorRequired] public Guid ConversationId { get; set; }
    [Parameter, EditorRequired] public int EpochId { get; set; }

    private const string CardStyle = "margin-top:6px;";

    private enum State { Pending, Loading, Loaded, Error }
    private State _state;

    /// <summary>Carica in automatico i file fino a questi byte; quelli più grandi richiedono un click.</summary>
    private const long AutoLoadThresholdBytes = 768 * 1024; // 768 KiB, comodamente sotto 1 MB

    protected override async Task OnInitializedAsync()
    {
        // I file piccoli vanno in preview inline; quelli grandi aspettano un click esplicito
        // così non decifriamo e streammiamo un video da 50 MB solo perché è entrato in vista.
        if (Attachment.Size <= AutoLoadThresholdBytes)
        {
            _state = State.Loading;
            await LoadAsync();
        }
        else
        {
            _state = State.Pending;
        }
    }
    private string? _blobUrl;
    private byte[]? _bytes;
    private string? _textPreview;
    private List<List<string>>? _csvRows;
    private string? _error;

    private bool IsImage => Attachment.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    private bool IsVideo => Attachment.MimeType.StartsWith("video/", StringComparison.OrdinalIgnoreCase);
    private bool IsAudio => Attachment.MimeType.StartsWith("audio/", StringComparison.OrdinalIgnoreCase);
    private bool IsPdf => Attachment.MimeType.Equals("application/pdf", StringComparison.OrdinalIgnoreCase);
    private bool IsCsv =>
        Attachment.MimeType.Equals("text/csv", StringComparison.OrdinalIgnoreCase)
        || Attachment.FileName.EndsWith(".csv", StringComparison.OrdinalIgnoreCase);
    private bool IsHtml =>
        Attachment.MimeType.Equals("text/html", StringComparison.OrdinalIgnoreCase)
        || Attachment.MimeType.Equals("application/xhtml+xml", StringComparison.OrdinalIgnoreCase)
        || Attachment.FileName.EndsWith(".html", StringComparison.OrdinalIgnoreCase)
        || Attachment.FileName.EndsWith(".htm", StringComparison.OrdinalIgnoreCase);
    private bool IsPlainText =>
        Attachment.MimeType.StartsWith("text/", StringComparison.OrdinalIgnoreCase)
        && !IsCsv && !IsHtml;

    private string TypeIcon => Attachment.MimeType switch
    {
        var m when m.StartsWith("image/") => "🖼️",
        var m when m.StartsWith("video/") => "🎬",
        var m when m.StartsWith("audio/") => "🎵",
        "application/pdf" => "📄",
        var m when m.Contains("spreadsheet") || Attachment.FileName.EndsWith(".xlsx") || Attachment.FileName.EndsWith(".xls") => "📊",
        var m when m.Contains("zip") || m.Contains("compressed") => "🗜️",
        _ => "📎"
    };

    private async Task LoadAsync()
    {
        _state = State.Loading;
        _error = null;
        StateHasChanged();
        try
        {
            _bytes = await ChatSdk.DownloadAttachmentAsync(ConversationId, Attachment, EpochId);

            if (IsCsv)
            {
                _csvRows = ParseCsv(System.Text.Encoding.UTF8.GetString(_bytes), maxRows: 200);
            }
            else if (IsPlainText)
            {
                var text = System.Text.Encoding.UTF8.GetString(_bytes);
                _textPreview = text.Length > 8000 ? text.Substring(0, 8000) + "…" : text;
            }
            else if (IsImage || IsVideo || IsAudio || IsPdf || IsHtml)
            {
                // Forziamo text/html sul blob per l'HTML così l'iframe lo renderizza come
                // documento anche se il mime dell'upload è sbagliato (es. application/octet-stream).
                var mime = IsHtml ? "text/html" : Attachment.MimeType;
                // Gli URL blob sono in 'self'-origin e molto più leggeri delle URL data: per file grossi.
                _blobUrl = await JS.InvokeAsync<string>(
                    "echatBlob.create", Convert.ToBase64String(_bytes), mime);
            }

            _state = State.Loaded;
        }
        catch (Exception ex)
        {
            _state = State.Error;
            _error = ex.Message;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!string.IsNullOrEmpty(_blobUrl))
        {
            try { await JS.InvokeVoidAsync("echatBlob.revoke", _blobUrl); } catch { }
            _blobUrl = null;
        }
    }

    private async Task DownloadAsync()
    {
        try
        {
            // Riusiamo i byte già decifrati per la preview, se li abbiamo.
            var bytes = _bytes ?? await ChatSdk.DownloadAttachmentAsync(ConversationId, Attachment, EpochId);
            await JS.InvokeVoidAsync("echatDownload",
                Convert.ToBase64String(bytes), Attachment.FileName, Attachment.MimeType);
        }
        catch (Exception ex)
        {
            _state = State.Error;
            _error = ex.Message;
        }
    }

    private static List<List<string>> ParseCsv(string text, int maxRows)
    {
        // Parser CSV minimale: gestisce celle tra virgolette e virgole dentro le virgolette.
        var rows = new List<List<string>>();
        var line = new List<string>();
        var cell = new System.Text.StringBuilder();
        bool inQuotes = false;
        for (int i = 0; i < text.Length && rows.Count < maxRows; i++)
        {
            var c = text[i];
            if (inQuotes)
            {
                if (c == '"')
                {
                    if (i + 1 < text.Length && text[i + 1] == '"') { cell.Append('"'); i++; }
                    else inQuotes = false;
                }
                else cell.Append(c);
            }
            else
            {
                if (c == '"') inQuotes = true;
                else if (c == ',') { line.Add(cell.ToString()); cell.Clear(); }
                else if (c == '\n')
                {
                    line.Add(cell.ToString()); cell.Clear();
                    rows.Add(line); line = new List<string>();
                }
                else if (c == '\r') { /* salta */ }
                else cell.Append(c);
            }
        }
        if (cell.Length > 0 || line.Count > 0)
        {
            line.Add(cell.ToString());
            rows.Add(line);
        }
        return rows;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }
}
