    private List<MemberDto> FilteredMembers()
    {
        if (_members is null || _members.Count == 0) return new();
        // Nascondi se stesso: l'utente non dovrebbe menzionarsi col suo account.
        IEnumerable<MemberDto> q = _members.Where(m => m.Id != _myDeviceId);
        if (!string.IsNullOrWhiteSpace(_mentionQuery))
        {
            var term = _mentionQuery.Trim();
            q = q.Where(m => m.DisplayName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true);
        }
        return q.Take(20).ToList();
    }

