    private async Task SearchUsers()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        _searchResults = await Http.GetFromJsonAsync<List<UserDto>>($"api/users/search?q={Uri.EscapeDataString(_searchQuery)}");
        StateHasChanged();
    }

    private async Task AddMember(Guid userId)
    {
        await Http.PostAsJsonAsync($"api/conversations/{ConversationId}/members", new { UserId = userId });
        // E2EE (S1): il server non copia più i wrap. Ri-wrappiamo la CEK corrente per i device del
        // nuovo membro così può leggere i messaggi dell'epoch corrente. Se il grant fallisce il membro
        // resta senza CEK: lo segnaliamo (riprovabile) invece di lasciare un'eccezione non gestita.
        try
        {
            await ChatSdk.GrantConversationKeysAsync(ConversationId);
        }
        catch (Exception ex)
        {
            _uploadStatus = $"Member added, but the key grant failed, so they can't read messages yet. Remove and re-add them to retry. ({ex.Message})";
            _ = ClearUploadStatusAfterDelayAsync();
        }
        _searchResults = null;
        _searchQuery = "";
        await LoadMembersInternal();
    }

    private async Task TransferOwnership(Guid targetUserId)
    {
        var response = await Http.PostAsJsonAsync($"api/conversations/{ConversationId}/transfer-ownership", new { TargetUserId = targetUserId });
        if (response.IsSuccessStatusCode)
        {
            _uploadStatus = "Ownership transferred.";
            await LoadMembersInternal();
        }
        else
        {
            var body = await response.Content.ReadAsStringAsync();
            _uploadStatus = $"Transfer failed ({(int)response.StatusCode}): {body}";
        }
        StateHasChanged();
        _ = ClearUploadStatusAfterDelayAsync();
    }

    private async Task ChangeRole(MembershipPanel.ChangeRoleRequest req)
    {
        try
        {
            await ChatSdk.SetMemberRoleAsync(ConversationId, req.UserId, req.Role);
            _uploadStatus = $"Role updated to {req.Role}.";
            await LoadMembersInternal();
        }
        catch (Exception ex)
        {
            _uploadStatus = $"Role change failed: {ex.Message}";
        }
        StateHasChanged();
        _ = ClearUploadStatusAfterDelayAsync();
    }

    private async Task RenameConversation(string newName)
    {
        try
        {
            await ChatSdk.RenameConversationAsync(ConversationId, newName);
            _conversationName = newName;
            _uploadStatus = "Conversation renamed.";
        }
        catch (Exception ex)
        {
            _uploadStatus = $"Rename failed: {ex.Message}";
        }
        StateHasChanged();
        _ = ClearUploadStatusAfterDelayAsync();
    }

    private async Task DeleteConversation()
    {
        try
        {
            await ChatSdk.DeleteConversationAsync(ConversationId);
            // La conversazione non esiste più: torna alla lista. Gli altri membri ricevono
            // ConversationChanged/Deleted via SignalR e fanno lo stesso.
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private async void OnConversationChanged(ConversationChangedEvent evt)
    {
        if (evt.ConversationId != ConversationId) return;
        try
        {
            await InvokeAsync(() =>
            {
                if (evt.ChangeType == "Renamed")
                {
                    _conversationName = evt.Name ?? _conversationName;
                    StateHasChanged();
                }
                else if (evt.ChangeType == "Deleted")
                {
                    Nav.NavigateTo("/");
                }
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[echat] OnConversationChanged (Chat) crashed: {ex}");
        }
    }

    /// <summary>
    /// Inserisce <paramref name="before"/>/<paramref name="after"/> intorno alla selezione corrente nella
    /// textarea markdown (id "echat-md-input"). Usato dai bottoni della toolbar. L'helper JS lancia
    /// anche un evento <c>input</c> così il binding Blazor coglie il nuovo valore.
    /// </summary>
    private async Task MdInsertAsync(string before, string after, string placeholder)
        => await JS.InvokeVoidAsync("echatMarkdown.wrap", "echat-md-input", before, after, placeholder);

    private async Task RemoveMember(MembershipPanel.RemoveMemberRequest request)
    {
        // FullReencrypt è lungo: il tracker mostra il banner via StateChanged; qui ci limitiamo
        // a creare un CTS così l'utente può Cancel dal banner stesso, e a beccare i casi
        // OperationCanceled per non sbattere un alert quando è un'azione voluta.
        var isFullReencrypt = request.Migration == MigrationMode.FullReencrypt;
        if (isFullReencrypt)
        {
            _migrationCts = new CancellationTokenSource();
            _cancelRequested = false;
            _stuckJobId = null;
            _stuckRemaining = null;
        }

        try
        {
            await ChatSdk.RemoveMemberAsync(
                ConversationId, request.UserId, request.Migration,
                progress: null,
                ct: _migrationCts?.Token ?? CancellationToken.None);
        }
        catch (OperationCanceledException) when (isFullReencrypt && _migrationCts is { IsCancellationRequested: true })
        {
            // Cancellazione esplicita dell'utente: nessun alert.
        }
        catch (MigrationIncompleteException incomplete)
        {
            // Custode non aveva le CEK per ri-cifrare tutto. Memorizziamo il jobId + il count
            // così il banner Failed può offrire "Force finalize". Non mostriamo l'alert
            // perché il banner stesso comunica chiaramente la situazione.
            _stuckJobId = incomplete.JobId;
            _stuckRemaining = incomplete.RemainingEnvelopes;
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Remove failed: {ex.Message}");
            return;
        }
        finally
        {
            // Atomic take-and-null per evitare la race con Dispose() della pagina che chiama
            // Cancel+Dispose sullo stesso CTS in parallelo a questo finally. Solo uno dei due
            // ottiene un riferimento non-null e fa Dispose; l'altro vede null e no-op.
            var cts = Interlocked.Exchange(ref _migrationCts, null);
            cts?.Dispose();
            _cancelRequested = false;
        }
        await LoadMembersInternal();
    }

    private async Task ForceFinalizeStuckMigration()
    {
        if (_stuckJobId is null || _stuckRemaining is null) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"FORCE FINALIZE will mark {_stuckRemaining} message(s) as permanently unreadable. " +
            $"This cannot be undone. Continue?");
        if (!confirmed) return;

        try
        {
            await ChatSdk.ForceFinalizeMigrationAsync(ConversationId, _stuckJobId.Value);
            _stuckJobId = null;
            _stuckRemaining = null;
            await JS.InvokeVoidAsync("alert", "Force-finalize complete. The conversation is rotated; the unreadable messages will show as decryption failures.");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Force-finalize failed: {ex.Message}");
        }
        await LoadMessages();
    }

    private void CancelMigration()
    {
        _cancelRequested = true;
        _migrationCts?.Cancel();
        StateHasChanged();
    }

    private void OnMigrationStateChanged(Guid conversationId)
    {
        if (conversationId == ConversationId)
            _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Realtime.OnMessageAvailable -= OnNewMessage;
        Realtime.OnMemberChanged -= OnMemberChanged;
        Realtime.OnMessageModerated -= OnMessageModerated;
        Realtime.OnConversationChanged -= OnConversationChanged;
        Realtime.OnConnectionStateChanged -= OnRealtimeConnectionChanged;
        MigrationTracker.StateChanged -= OnMigrationStateChanged;
        _newMessageLock.Dispose();
        // Atomic take-and-null: evita la race con il finally di RemoveMember che potrebbe star
        // disponendo lo stesso CTS in parallelo. CancellationTokenSource.Dispose non è safe per
        // chiamate concorrenti.
        var cts = Interlocked.Exchange(ref _migrationCts, null);
        cts?.Cancel();
        cts?.Dispose();
        AiService.Disable();
        // Stacca tutti i listener click-outside che potremmo aver lasciato attaccati. Ogni off()
        // è dentro il suo try perché se uno fallisce non deve far saltare gli altri.
        foreach (var id in new[] { _formatMenuClickOutsideId, _mentionPickerClickOutsideId, _emojiPickerClickOutsideId })
        {
            if (id > 0)
            {
                try { _ = JS.InvokeVoidAsync("echatClickOutside.off", id); } catch { }
            }
        }
        _formatMenuClickOutsideId = 0;
        _mentionPickerClickOutsideId = 0;
        _emojiPickerClickOutsideId = 0;
        _selfRef?.Dispose();
    }

}
