@page "/conversations/{ConversationId:guid}"
@attribute [Authorize]
@using ECHAT.Client.App.Components
@using ECHAT.Client.App.Services
@using ECHAT.Client.Core.Interfaces
@using ECHAT.Models.Domain
@using ECHAT.Models.Dtos
@using ECHAT.Models.Enums
@using ECHAT.Models.Events
@using Microsoft.AspNetCore.Components.Forms
@inject ChatSdkService ChatSdk
@inject SignalRRealtimeClient Realtime
@inject IMigrationStateTracker MigrationTracker
@inject HttpClient Http
@inject TokenAuthStateProvider AuthState
@inject NavigationManager Nav
@inject AiAutoReplyService AiService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Chat · ECHAT</PageTitle>

<div id="chat-page" style="display:flex; flex-direction:column; height:100vh; overflow:hidden; position:relative;">
    @* Overlay di drop su tutta la pagina: appare quando il JS aggiunge .echat-dragging su #chat-page *@
    <div class="echat-drop-overlay">
        <div>Drop files anywhere to send</div>
    </div>

    <div style="padding:12px 16px; border-bottom:1px solid #e0e0e0; display:flex; align-items:center; gap:12px;">
        <h4 style="margin:0; flex:1;">@_conversationName</h4>
        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleMembers">@(_isAdmin ? "Manage" : "Members")</button>
    </div>

    @if (_showMembers)
    {
        <MembershipPanel Members="_members"
                         MyDeviceId="_myDeviceId"
                         IsAdmin="_isAdmin"
                         IsOwner="_isOwner"
                         SearchQuery="@_searchQuery"
                         SearchResults="_searchResults"
                         ConversationName="@_conversationName"
                         OnTransferOwnership="TransferOwnership"
                         OnRemoveMember="RemoveMember"
                         OnAddMember="AddMember"
                         OnChangeRole="ChangeRole"
                         OnRename="RenameConversation"
                         OnDeleteConversation="DeleteConversation"
                         OnSearch="SearchUsers"
                         OnSearchQueryChanged="@(v => _searchQuery = v)" />
    }

    @* Banner persistente per saga incompleta: il custode non è riuscito a ri-cifrare alcuni
       envelope perché non aveva le CEK per quei vecchi epoch. Resta visibile (no auto-clear)
       finché l'utente decide se cancellare oppure forzare il finalize accettando la perdita. *@
    @if (_stuckJobId is not null && _stuckRemaining is not null)
    {
        <div style="padding:10px 16px; background:#fff3e0; border-bottom:1px solid #f0c995; display:flex; align-items:center; gap:12px;">
            <span style="font-size:1.1em; color:#e65100;">⚠</span>
            <div style="flex:1;">
                <strong style="color:#e65100;">Migration incomplete</strong>
                <span style="margin-left:6px; color:#555; font-size:0.9em;">
                    @_stuckRemaining message(s) could not be re-encrypted because your account doesn't have the keys for those older epochs.
                </span>
                <div style="margin-top:4px; font-size:0.85em; color:#666;">
                    Options: ask the conversation Owner to run the rotation instead, or force-finalize to accept the loss
                    (those @_stuckRemaining message(s) become permanently unreadable).
                </div>
            </div>
            <button class="btn btn-sm btn-danger" style="font-size:0.85em;" @onclick="ForceFinalizeStuckMigration"
                    title="Crypto-shred the old keys regardless. The unreachable messages become permanently unreadable.">
                Force finalize (lose @_stuckRemaining)
            </button>
            <button class="btn btn-sm btn-outline-secondary" style="font-size:0.85em;"
                    @onclick="() => { _stuckJobId = null; _stuckRemaining = null; }">
                Dismiss
            </button>
        </div>
    }

    @* Banner di migrazione FullReencrypt: si autocompila da IMigrationStateTracker, quindi
       reagisce sia alle saghe locali (IProgress del custode) sia a quelle guidate da altri
       device sulla stessa conversazione (JobProgressEvent via SignalR).
       Il composer è bloccato finché MigrationTracker.IsActive ritorna true (= fase non
       terminale). Le fasi terminali restano visibili ~2.5s per dare feedback. *@
    @{
        var migState = MigrationTracker.Get(ConversationId);
    }
    @if (migState is not null)
    {
        // _cancelRequested è true tra il click su Cancel e l'arrivo della fase Cancelled.
        // In quella finestra mostriamo "Cancelling…" così l'utente vede subito l'effetto.
        var isCancelling = _cancelRequested
            && migState.Phase is MigrationPhase.Starting or MigrationPhase.Reencrypting or MigrationPhase.Finalizing;

        var percent = migState.Total is > 0
            ? Math.Min(100, (int)(100L * migState.Processed / migState.Total.Value))
            : (migState.Total is null && migState.Processed is > 0 and <= 100 ? migState.Processed : (int?)null);

        // Tail "+ N skipped" se il custode non è riuscito a ri-cifrare alcuni envelope
        // (CEK mancante per quel vecchio epoch, di solito perché l'utente attuale è entrato
        // nella conversazione dopo, senza includeHistory). Quegli envelope restano al vecchio
        // epoch e il safety check del server impedirà il finalize finché qualcuno con le CEK
        // giuste non finisce il lavoro.
        var skipText = migState.Skipped > 0 ? $" (+ {migState.Skipped} skipped, missing keys)" : "";

        var statusText = isCancelling
            ? "Cancelling…"
            : migState.Phase switch
            {
                MigrationPhase.Starting    => "Starting…",
                MigrationPhase.Reencrypting => migState.Total is > 0
                    ? $"Re-encrypted {migState.Processed} of {migState.Total} message(s){skipText}"
                    : (migState.Total is null && percent is not null
                        ? $"~{percent}% (remote)"
                        : $"Re-encrypted {migState.Processed} message(s){skipText}"),
                MigrationPhase.Finalizing  => "Finalizing & crypto-shredding old keys…",
                MigrationPhase.Completed   => "Completed",
                MigrationPhase.Cancelled   => "Cancelled (partial state preserved)",
                MigrationPhase.Failed      => $"Failed: {migState.Error}",
                _ => ""
            };

        // Palette per fase: feedback colorato chiaro per Completed/Cancelled/Failed così l'esito
        // si distingue a colpo d'occhio anche se la finestra dura solo 2.5s.
        var (bg, border, accent, icon, headerText) = migState.Phase switch
        {
            MigrationPhase.Completed => ("#e8f5e9", "#a3d5ad", "#2e7d32", "✓", "Re-encryption completed"),
            MigrationPhase.Cancelled => ("#fff3e0", "#f0c995", "#e65100", "⏹", "Re-encryption cancelled"),
            MigrationPhase.Failed    => ("#fde2e2", "#e9a4a4", "#b71c1c", "⚠", "Re-encryption failed"),
            _                        => ("#e7f1fb", "#bcd4ee", "#1264a3", "",  "Re-encrypting history…")
        };

        <div style="padding:10px 16px; background:@bg; border-bottom:1px solid @border; display:flex; align-items:center; gap:12px;">
            @if (string.IsNullOrEmpty(icon))
            {
                <div class="spinner-border spinner-border-sm" role="status" style="width:1rem; height:1rem; color:@accent;"></div>
            }
            else
            {
                <span style="font-size:1.1em; color:@accent;">@icon</span>
            }
            <div style="flex:1;">
                <strong style="color:@accent;">@headerText</strong>
                <span style="margin-left:6px; color:#555; font-size:0.9em;">@statusText</span>
                @if (percent is not null && !IsTerminalPhase(migState.Phase))
                {
                    <div style="margin-top:6px; height:6px; background:#cfe1f5; border-radius:3px; overflow:hidden;">
                        <div style="height:100%; width:@(percent)%; background:@accent; transition:width 0.2s;"></div>
                    </div>
                }
            </div>
            @if (!IsTerminalPhase(migState.Phase))
            {
                <span style="font-size:0.85em; color:#777;">Sending paused</span>
            }
            @if (_migrationCts is not null && !_migrationCts.IsCancellationRequested
                 && !IsTerminalPhase(migState.Phase))
            {
                <button class="btn btn-sm btn-outline-danger" style="font-size:0.8em;" @onclick="CancelMigration"
                        title="Stop the re-encryption. Already-rewritten messages keep the new keys; the rest stay on the old keys.">
                    Cancel
                </button>
            }
            else if (isCancelling)
            {
                <span style="font-size:0.8em; color:#888; font-style:italic;">Cancelling…</span>
            }
        </div>
    }

    <div style="flex:1; overflow-y:auto; padding:16px;" id="messages-container" @onscroll="OnScroll">
        @if (_keyAccessError is not null)
        {
            <div style="background:#fde2e1; border:1px solid #f1b0ac; color:#7a1f1a; border-radius:8px; padding:12px 14px; margin-bottom:12px; font-size:.88rem;">
                <div style="display:flex; justify-content:space-between; gap:8px; align-items:flex-start;">
                    <div><strong>This device can't open this conversation.</strong><br />@_keyAccessError</div>
                    <button class="sidebar-logout" @onclick="() => _keyAccessError = null" title="Dismiss">✕</button>
                </div>
                <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
                    <button class="sidebar-btn-create" @onclick="RestoreKeyFromBanner">Restore key from file…</button>
                </div>
            </div>
        }
        @if (_loadingOlder)
        {
            <div style="text-align:center; padding:8px; color:#888; font-size:0.85em;">Loading older messages…</div>
        }
        @if (_messages == null)
        {
            <p>Loading messages...</p>
        }
        else if (_messages.Count == 0 && _keyAccessError is null)
        {
            <p style="color:#888; text-align:center;">No messages yet. Say something!</p>
        }
        else
        {
            @for (int idx = 0; idx < _messages.Count; idx++)
            {
                var msg = _messages[idx];
                if (msg.Invisible) continue;

                var prevMsg = idx > 0 ? _messages[idx - 1] : null;
                var showHeader = prevMsg == null || prevMsg.SenderUserId != msg.SenderUserId || prevMsg.Invisible;

                @* @key sul MessageId: tiene ogni MessageBubble (e il suo AttachmentPreview figlio)
                   legato al suo messaggio reale. Senza questo, quando LoadMessages SOSTITUISCE la lista
                   dopo un upload, Blazor riusa i componenti per posizione; un'immagine appena caricata
                   finirebbe in uno slot il cui AttachmentPreview ha ancora lo stato vecchio dell'occupante
                   precedente, quindi OnInitializedAsync non ripartirebbe e l'auto-load non girerebbe mai. *@
                <MessageBubble @key="msg.MessageId"
                               Message="msg"
                               ConversationId="ConversationId"
                               Sender="GetSender(msg.SenderUserId)"
                               ShowHeader="showHeader"
                               IsExpanded="_expandedInfoIds.Contains(msg.MessageId)"
                               OnToggleInfo="ToggleInfo"
                               CanModerate="CanModerateMessage(msg)"
                               OnModerate="(bool hidden) => ModerateMessage(msg, hidden)" />
            }
        }
    </div>

    @if (_uploadStatus is not null)
    {
        <div style="padding:6px 16px; background:#fff8db; border-top:1px solid #f0e7a0; font-size:0.85em; color:#55471d;">
            @_uploadStatus
        </div>
    }

    @* Card composer in stile V1: toolbar + input + footer in un'unica superficie
       arrotondata con focus ring gestito da :focus-within. Il selettore del formato
       ora è un menu dropdown nella toolbar (sostituisce la vecchia riga di toggle);
       i bottoni di formattazione (Bold/Italic/ecc.) appaiono solo in modalità Markdown. *@
    <div class="echat-composer" @ref="_composerRef">
        <div class="echat-composer-toolbar">
            <div class="echat-format-menu" @ref="_formatMenuRef">
                <button type="button"
                        class="echat-format-btn @(_showFormatMenu ? "open" : "")"
                        @onclick="ToggleFormatMenu"
                        title="Change message format">
                    @SvgIcon("format")
                    <span>@FormatLabel(_format)</span>
                    @SvgIcon("caret")
                </button>
                @if (_showFormatMenu)
                {
                    <div class="echat-format-popup">
                        @foreach (var opt in _formatOptions)
                        {
                            <button type="button"
                                    class="echat-format-option @(_format == opt.Format ? "active" : "")"
                                    @onclick="@(() => PickFormat(opt.Format))">
                                <span class="check">@SvgIcon("check")</span>
                                <span class="info">
                                    <div class="label">@opt.Label</div>
                                    <div class="hint">@opt.Hint</div>
                                </span>
                                <span class="kbd">@opt.Kbd</span>
                            </button>
                        }
                    </div>
                }
            </div>

            @if (_format == MessageFormat.Markdown)
            {
                <span class="sep"></span>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Bold ⌘B" @onclick="@(() => MdInsertAsync("**", "**", "text"))">@SvgIcon("bold")</button>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Italic ⌘I" @onclick="@(() => MdInsertAsync("*", "*", "text"))">@SvgIcon("italic")</button>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Strike" @onclick="@(() => MdInsertAsync("~~", "~~", "text"))">@SvgIcon("strike")</button>
                <span class="sep"></span>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Inline code" @onclick="@(() => MdInsertAsync("`", "`", "code"))">@SvgIcon("code")</button>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Code block" @onclick="@(() => MdInsertAsync("\n```\n", "\n```\n", "code"))">@SvgIcon("block")</button>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Quote" @onclick="@(() => MdInsertAsync("\n> ", "", "quote"))">@SvgIcon("quote")</button>
                <span class="sep"></span>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Bulleted list" @onclick="@(() => MdInsertAsync("\n- ", "", "list item"))">@SvgIcon("list")</button>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Numbered list" @onclick="@(() => MdInsertAsync("\n1. ", "", "list item"))">@SvgIcon("ol")</button>
                <button class="echat-tb-btn" type="button" disabled="@_sending"
                        title="Link ⌘K" @onclick="@(() => MdInsertAsync("[", "](https://...)", "text"))">@SvgIcon("link")</button>
            }

            <span class="spacer"></span>

            <div class="echat-popover-wrap" @ref="_mentionPickerRef">
                <button class="echat-tb-btn @(_showMentionPicker ? "active" : "")"
                        type="button" disabled="@_sending"
                        title="Mention a member" @onclick="ToggleMentionPickerAsync">@SvgIcon("at")</button>
                @if (_showMentionPicker)
                {
                    <div class="echat-popover echat-mention-popup">
                        <input class="echat-mention-search" @ref="_mentionSearchRef"
                               @bind="_mentionQuery" @bind:event="oninput"
                               placeholder="Search members…"
                               @onkeydown="OnMentionSearchKeyDown" />
                        @{ var matches = FilteredMembers(); }
                        @if (matches.Count == 0)
                        {
                            <div class="echat-mention-empty">No matches</div>
                        }
                        else
                        {
                            <div class="echat-mention-list">
                                @foreach (var m in matches)
                                {
                                    <button type="button" class="echat-mention-item"
                                            @onclick="@(() => PickMentionAsync(m))">
                                        <img src="api/avatar/@m.Id" alt="" />
                                        <span class="name">@m.DisplayName</span>
                                        @if (!string.IsNullOrEmpty(m.Role) && m.Role != "Member")
                                        {
                                            <span class="role">@m.Role</span>
                                        }
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="echat-popover-wrap" @ref="_emojiPickerRef">
                <button class="echat-tb-btn @(_showEmojiPicker ? "active" : "")"
                        type="button" disabled="@_sending"
                        title="Emoji" @onclick="ToggleEmojiPickerAsync">@SvgIcon("smile")</button>
                @if (_showEmojiPicker)
                {
                    <div class="echat-popover echat-emoji-popup">
                        <div class="echat-emoji-grid">
                            @foreach (var emoji in CommonEmojis)
                            {
                                <button type="button" class="echat-emoji-btn"
                                        title="@emoji"
                                        @onclick="@(() => PickEmojiAsync(emoji))">@emoji</button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="echat-composer-input">
            <label class="echat-composer-attach" title="@(_migrationActive ? "Sending disabled during re-encryption" : "Attach files (or drag-and-drop)")"
                   style="@(_migrationActive ? "opacity:0.4; pointer-events:none;" : "")">
                @SvgIcon("attach")
                <InputFile id="echat-file-input" OnChange="OnFilePicked" multiple style="display:none;" disabled="@_migrationActive" />
            </label>
            <div class="echat-composer-textarea-wrap">
                @* Sempre una textarea così anche Plain può essere multi-riga (Shift+Enter inserisce
                   un newline, Enter invia). L'attributo data-echat-format permette a `echat.js` di
                   intercettare Enter sulle textarea Plain con preventDefault; altrimenti il newline
                   nativo finirebbe nel valore dell'input prima che il nostro handler SendMessage lo legga. *@
                <textarea id="echat-md-input"
                          data-echat-format="@_format.ToString().ToLowerInvariant()"
                          data-echat-autogrow="240"
                          @bind="_inputText" @bind:event="oninput" @onkeydown="OnKeyDown"
                          placeholder="@(_migrationActive ? "Sending paused while re-encryption is in progress…" : PlaceholderForFormat(_format, _conversationName))"
                          rows="3"
                          disabled="@_migrationActive"
                          style="font-family:@(_format == MessageFormat.Html ? "var(--bs-font-monospace, monospace)" : "inherit");"></textarea>
            </div>
        </div>

        <div class="echat-composer-footer">
            @if (_format == MessageFormat.Plain)
            {
                <span><kbd>⏎</kbd> to send · <kbd>⇧⏎</kbd> for newline</span>
            }
            else
            {
                <span><kbd>⌘⏎</kbd> to send · <kbd>⏎</kbd> for newline</span>
            }
            @if (_format == MessageFormat.Html)
            {
                <span style="margin-left:6px;">· Sandboxed iframe, scripts blocked</span>
            }
            <span class="spacer"></span>
            <div class="echat-send-split">
                <button type="button" class="send" @onclick="SendMessage"
                        disabled="@(_sending || _migrationActive || string.IsNullOrWhiteSpace(_inputText))">
                    @SvgIcon("send")
                    Send
                </button>
                <button type="button"
                        class="ai @(_aiEnabled ? "ai-on" : "")"
                        @onclick="ToggleAi"
                        disabled="@_migrationActive"
                        title="@(_migrationActive ? "Disabled during re-encryption" : (_aiEnabled ? "AI auto-reply is on. Click to disable." : "Enable AI auto-reply"))">
                    @SvgIcon("sparkle")
                    @(_aiEnabled ? "AI ON" : "AI")
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .msg-row:hover { background: #f8f8f8; }
    .msg-row:hover .msg-actions { opacity: 1 !important; }

    /* Overlay di drop: nascosto finché il JS non mette .echat-dragging sul container */
    .echat-drop-overlay {
        position: absolute; inset: 0;
        display: none;
        align-items: center; justify-content: center;
        background: rgba(18, 100, 163, 0.08);
        border: 3px dashed #1264a3;
        border-radius: 8px;
        font-size: 1.4em; font-weight: 600; color: #1264a3;
        pointer-events: none; /* non intercettare gli eventi di drag; lasciali al container */
        z-index: 5;
    }
    .echat-dragging .echat-drop-overlay { display: flex; }
</style>

@code {
    [Parameter] public Guid ConversationId { get; set; }

    private Guid _loadedConversationId;
    private string _conversationName = "...";
    private List<DecryptedMessage>? _messages;
    private string _inputText = "";
    private bool _sending;
    private CancellationTokenSource? _migrationCts;
    private bool _cancelRequested;
    // Stato per recovery "force finalize": popolato dal catch di RemoveMember quando la saga
    // fallisce con MigrationIncompleteException. La UI mostra un bottone destructive solo se
    // questi sono valorizzati.
    private Guid? _stuckJobId;
    private int? _stuckRemaining;
    private bool _migrationActive => MigrationTracker.IsActive(ConversationId);
    private static bool IsTerminalPhase(MigrationPhase p)
        => p is MigrationPhase.Completed or MigrationPhase.Cancelled or MigrationPhase.Failed;

    // Serializza OnNewMessage: SignalR può consegnare un burst di MessageAvailable (es. molti
    // file inviati uno dopo l'altro), ognuno scatena un'invocazione async void. Senza lock,
    // tutte leggono lo stesso lastSeq prima che la prima abbia appeso  fetch ridondanti +
    // possibili messaggi persi. Il semaforo garantisce un'invocazione alla volta.
    private readonly SemaphoreSlim _newMessageLock = new(1, 1);

    private bool _showMembers;
    private List<MemberDto>? _members;
    private Dictionary<Guid, MemberDto> _membersMap = new();
    private Guid _myDeviceId;
    private HashSet<Guid> _expandedInfoIds = new();
    private bool _aiEnabled;
    private string _searchQuery = "";
    private List<UserDto>? _searchResults;
    private bool _isAdmin;
    private bool _isOwner;
    private string? _myRole;   // ruolo del viewer nella conversazione (per i controlli di moderazione)
    private string? _uploadStatus;
    // Banner persistente mostrato quando questo device non possiede la chiave giusta per la
    // conversazione (CEK wrappata per un'altra chiave): es. browser nuovo o storage azzerato.
    private string? _keyAccessError;
    private const string KeyAccessErrorText =
        "The encryption key on this browser doesn't match this conversation. This happens on a new browser or after clearing storage. "
        + "Restore your saved key file to regain access, or ask a conversation admin to re-share the key (Rotate).";
    private const long MaxUploadBytes = 25L * 1024 * 1024; // limite UI da 25 MiB (il server limita ogni parte a 2 MiB)
    private MessageFormat _format = MessageFormat.Plain;

    // Composer V1: stato del dropdown del formato e gestione del click fuori.
    private bool _showFormatMenu;
    private ElementReference _composerRef;
    private ElementReference _formatMenuRef;
    private DotNetObjectReference<Chat>? _selfRef;
    private int _formatMenuClickOutsideId;

    private bool _showMentionPicker;
    private ElementReference _mentionPickerRef;
    private ElementReference _mentionSearchRef;
    private string _mentionQuery = string.Empty;
    private int _mentionPickerClickOutsideId;
    private bool _mentionShouldFocus;

    private bool _showEmojiPicker;
    private ElementReference _emojiPickerRef;
    private int _emojiPickerClickOutsideId;

    // Set curato di emoji comuni per la chat. Lista piatta (niente categorie) così il
    // picker resta piccolo e veloce. Mix di facce, gesti, cuori e simboli usati di frequente.
    private static readonly string[] CommonEmojis = new[]
    {
        "😀","😄","😁","😆","😅","🤣","😂","🙂",
        "🙃","😉","😊","😇","🥰","😍","😘","😋",
        "😎","🤓","🤩","🥳","🤔","🤨","😐","😑",
        "😶","🙄","😏","😒","😞","😔","😟","😕",
        "🙁","😣","😩","😢","😭","😤","😡","🤬",
        "👍","👎","👌","✌️","🤞","🤟","🤘","🤙",
        "👈","👉","☝️","👋","🙏","👏","💪","🤝",
        "❤️","🧡","💛","💚","💙","💜","🖤","🤍",
        "🔥","✨","🎉","🎊","🚀","⭐","💯","✅",
        "❌","❓","❗","⚠️","💡","📌","🔗","🎯",
    };

    private record FormatOption(MessageFormat Format, string Label, string Hint, string Kbd);
    private static readonly FormatOption[] _formatOptions =
    {
        new(MessageFormat.Plain,    "Plain",    "No formatting",            "⌘⇧P"),
        new(MessageFormat.Markdown, "Markdown", "# heading, **bold**, code", "⌘⇧M"),
        new(MessageFormat.Html,     "HTML",     "Raw <tags>, sandboxed",     "⌘⇧H"),
    };

    private static string FormatLabel(MessageFormat f) => f switch
    {
        MessageFormat.Plain => "Plain",
        MessageFormat.Markdown => "Markdown",
