    private async Task LoadConversation()
    {
        try
        {
            var conv = await Http.GetFromJsonAsync<ConversationDto>($"api/conversations/{ConversationId}");
            _conversationName = conv?.Name ?? "Chat";
        }
        catch { _conversationName = "Chat"; }
    }

    private async Task LoadMembersInternal()
    {
        try
        {
            _members = await Http.GetFromJsonAsync<List<MemberDto>>($"api/conversations/{ConversationId}/members");
            _membersMap = _members?.ToDictionary(m => m.Id) ?? new();
            var myMembership = _members?.FirstOrDefault(m => m.Id == _myDeviceId);
            _myRole = myMembership?.Role;
            _isOwner = myMembership?.Role == "Owner";
            _isAdmin = myMembership?.Role == "Owner" || myMembership?.Role == "Admin";
        }
        catch { _members = new(); _membersMap = new(); _isAdmin = false; _isOwner = false; _myRole = null; }
    }

    private const int InitialPageSize = 50;
    private const int OlderPageSize = 50;
    private bool _loadingOlder;
    private bool _hasMoreOlder = true;

    private async Task LoadMessages()
    {
        // Stessa _newMessageLock di OnNewMessage: un fetch completo che assegna _messages = ...
        // mentre un OnNewMessage incrementale sta appendendo sull'istanza VECCHIA della lista
        // perderebbe i messaggi appena ricevuti dal SignalR. Acquisendo lo stesso semaforo
        // serializziamo questi due flussi.
        await _newMessageLock.WaitAsync();
        try
        {
            try
            {
                // Apertura iniziale: il server restituisce i più recenti InitialPageSize messaggi, in ordine crescente.
                _messages = await ChatSdk.FetchMessagesAsync(ConversationId, null, null, InitialPageSize);
                // Server li ordina per Seq (necessario per la chain). Per la UI riordiniamo per
                // CreatedAt: vedi commento in OnNewMessage sui seq pre-riservati.
                SortMessagesForDisplay(_messages);
                _hasMoreOlder = _messages.Count == InitialPageSize;
                _keyAccessError = null; // fetch riuscito  la chiave va bene: rimuovi un eventuale banner
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[echat] LoadMessages failed: {ex.Message}");
                _messages = new();
                _hasMoreOlder = false;
                if (IsKeyAccessError(ex)) _keyAccessError = KeyAccessErrorText;
            }
        }
        finally
        {
            _newMessageLock.Release();
        }
        await ScrollToBottomNow();
    }

    /// <summary>
    /// Recupera il prossimo batch di messaggi più vecchi (chiamata quando l'utente scrolla in cima).
    /// Mantiene la posizione di scroll così i messaggi già visibili non saltano.
    /// </summary>
    private async Task LoadOlderAsync()
    {
        if (_loadingOlder || !_hasMoreOlder || _messages is null || _messages.Count == 0) return;

        _loadingOlder = true;
        StateHasChanged();
        try
        {
            // Cursore SEMPRE per Seq (lo richiede l'endpoint del server). Non possiamo usare
            // _messages[0].Seq perché ora la lista è ordinata per CreatedAt: il primo per
            // display potrebbe non essere il più basso per Seq.
            var oldestSeq = _messages.Min(m => m.Seq);
            // Salva la distanza dal fondo così possiamo ripristinare lo scroll dopo il prepend.
            var prevScrollHeight = await JS.InvokeAsync<double>("eval",
                "document.getElementById('messages-container')?.scrollHeight ?? 0");

            var older = await ChatSdk.FetchMessagesAsync(ConversationId, null, oldestSeq, OlderPageSize);
            if (older.Count == 0)
            {
                _hasMoreOlder = false;
                return;
            }
            _hasMoreOlder = older.Count == OlderPageSize;

            // Merge + risorting per display. Dedup per MessageId per gestire eventuali overlap.
            var existingIds = _messages.Select(m => m.MessageId).ToHashSet();
            foreach (var m in older.Where(x => !existingIds.Contains(x.MessageId)))
                _messages.Add(m);
            SortMessagesForDisplay(_messages);
            StateHasChanged();

            // Ripristina lo scroll così la vista dell'utente non salta.
            await JS.InvokeVoidAsync("eval",
                $"(function(){{var el=document.getElementById('messages-container');if(!el)return;el.scrollTop=el.scrollHeight-{prevScrollHeight.ToString(System.Globalization.CultureInfo.InvariantCulture)};}})()");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[echat] LoadOlderAsync failed: {ex.Message}");
        }
        finally
        {
            _loadingOlder = false;
            StateHasChanged();
        }
    }

    private async void OnScroll()
    {
        try
        {
            var state = await JS.InvokeAsync<ScrollState>(
                "echatScroll.getState", "messages-container", 150);
            if (!state.Exists) return;

            // Scatta quando siamo entro 80 px dal top.
            if (state.Top < 80 && !_loadingOlder && _hasMoreOlder)
                await LoadOlderAsync();

            // Ogni volta che l'utente torna vicino al fondo della conversazione attiva,
            // chiediamo a MainLayout di azzerare il contatore dei non letti per questa conv.
            // Costa poco: è solo un'interop JS che si risolve in un remove sul dizionario
            // più uno StateHasChanged in MainLayout.
            if (state.NearBottom)
                await JS.InvokeVoidAsync("echatRead.markRead", ConversationId.ToString());
        }
        catch { /* ignora */ }
    }

    private record ScrollState(bool Exists, double Top, bool NearBottom);

    private async Task ScrollToBottomNow()
    {
        // Il render iniziale dispone i messaggi, ma i componenti AttachmentPreview continuano
        // a spingere su scrollHeight man mano che <img>/<iframe>/blob: finiscono di decodificare;
        // un singolo `scrollTop = scrollHeight` atterra sopra il fondo. L'helper sticky riancora
        // al fondo a ogni animation frame per ~900 ms (o finché l'utente non scrolla), che è
        // più che sufficiente per la preview più lenta su una pagina tipica.
        await Task.Yield();
        try { await JS.InvokeVoidAsync("echatScroll.toBottomSticky", "messages-container", 900); }
        catch { }
    }

    private async void OnMemberChanged(MemberChangedEvent evt)
    {
        if (evt.ConversationId != ConversationId) return;

        // Race noto: lo stesso evento "Removed" arriva a MainLayout (che ci naviga via
        // dalla pagina, async) e a Chat.razor in parallelo. Se sei TU il rimosso, GET /members
        // qui sotto restituisce 403 (ListMembersAsync esige membership attiva), e il server
        // logga una ForbiddenException ogni volta. Skip esplicito: per te il refresh non serve,
        // la navigazione di MainLayout sostituisce la pagina.
        if (evt.Action == "Removed" && evt.UserId == _myDeviceId) return;

        try
        {
            await InvokeAsync(async () =>
            {
                await LoadMembersInternal();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[echat] OnMemberChanged (Chat) crashed: {ex}");
        }
    }

    // Un messaggio è stato nascosto/ri-mostrato (da noi o da un altro moderatore): ricarichiamo così
    // l'orchestratore riapplica i flag e, in caso di unhide, ridecifra il contenuto da mostrare.
    private async void OnMessageModerated(MessageModeratedEvent evt)
    {
        if (evt.ConversationId != ConversationId) return;
        try
        {
            await InvokeAsync(async () =>
            {
                await LoadMessages();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[echat] OnMessageModerated (Chat) crashed: {ex}");
        }
    }

    // Gerarchia ruoli (mirror lato client di MessageModerationService.Rank): Owner>Admin>Moderator>Member.
    private static int RoleRank(string? role) => role switch
    {
        "Owner" => 3, "Admin" => 2, "Moderator" => 1, _ => 0
    };

    // Il viewer può moderare QUESTO messaggio se ha il permesso (ruolo >= Moderator) e o è il proprio
    // messaggio o supera in grado il mittente. La regola è ri-validata lato server (questo è solo UI).
    private bool CanModerateMessage(DecryptedMessage msg)
    {
        var myRank = RoleRank(_myRole);
        if (myRank < 1) return false;                       // né Owner/Admin/Moderator  nessun controllo
        if (msg.SenderUserId == _myDeviceId) return true;   // proprio messaggio
        var senderRole = _membersMap.TryGetValue(msg.SenderUserId, out var s) ? s.Role : null;
        return RoleRank(senderRole) <= myRank;
    }

    private async Task ModerateMessage(DecryptedMessage msg, bool hidden)
    {
        try
        {
            await ChatSdk.ModerateMessageAsync(ConversationId, msg.Seq, hidden, null);
            await LoadMessages(); // l'evento realtime ricaricherebbe comunque; questo è per reattività immediata
        }
        catch (Exception ex)
        {
            _uploadStatus = $"Moderation failed: {ex.Message}";
            _ = ClearUploadStatusAfterDelayAsync();
        }
    }

    private async void OnNewMessage(MessageAvailableEvent evt)
    {
        try
        {
            if (evt.ConversationId != ConversationId) return;

            // Un solo handler alla volta. Senza il lock, un burst di SignalR (10 file in fila)
            // scatena 10 async void in parallelo; ciascuno legge lo stesso "ultimo seq" e fa
            // fetch ridondanti che competono fra loro. Con il lock il flusso è serializzato.
            await _newMessageLock.WaitAsync();
            try
            {
                await InvokeAsync(async () =>
                {
                    // MAX(Seq), non LastOrDefault: il display può essere arrivato fuori ordine
                    // (lease per-client  seq non strettamente monotonici nel tempo di arrivo),
                    // quindi l'ultimo della lista per posizione potrebbe avere seq inferiore al
                    // massimo. afterSeq=Max è l'unico cursore corretto per un incrementale.
                    var lastSeq = _messages is { Count: > 0 } ? _messages.Max(m => m.Seq) : (long?)null;
                    var newMsgs = await ChatSdk.FetchMessagesAsync(ConversationId, lastSeq, null, 50);
                    Console.WriteLine($"[echat] OnNewMessage: evt.Seq={evt.Seq} fetched={newMsgs.Count} after={lastSeq}");

                    if (_messages != null && newMsgs.Count > 0)
                    {
                        var added = false;
                        foreach (var m in newMsgs)
                        {
                            if (_messages.All(x => x.MessageId != m.MessageId))
                            {
                                _messages.Add(m);
                                added = true;
                            }
                        }
                        // Display sort = CreatedAt + Seq tiebreaker.
                        // I seq vengono dalle reservation per-client (lease batch), quindi
                        // l'ordine numerico NON è cronologico: l'AI auto-reply che gira sulla
                        // sessione di un membro consuma uno dei suoi seq pre-allocati e può
                        // risultare numericamente PRIMA del messaggio originale che sta
                        // rispondendo. CreatedAt è assegnato server-side al persist, quindi
                        // riflette l'ordine reale di ingestion. La chain validation resta su
                        // seq-order (FetchMessagesAsync visita gli envelope nell'ordine in cui
                        // li restituisce il server, che è per seq): display e chain sono
                        // ortogonali, va bene così.
                        if (added)
                        {
                            SortMessagesForDisplay(_messages);
                            StateHasChanged();
                            await ScrollToBottomIfNeeded();
                        }
                    }
                });
            }
            finally
            {
                _newMessageLock.Release();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[echat] OnNewMessage handler crashed: {ex}");
        }
    }

    /// <summary>
    /// Ordina la lista per visualizzazione: CreatedAt asc, Seq asc come tiebreaker. Vedi
    /// commento in OnNewMessage: il display ha senso cronologico solo per CreatedAt perché
    /// i seq sono pre-riservati per-client e arrivano fuori ordine quando più mittenti
    /// (utente + AI) inviano in parallelo.
    /// </summary>
    private static void SortMessagesForDisplay(List<DecryptedMessage> messages)
    {
        messages.Sort((a, b) =>
        {
            var c = a.CreatedAt.CompareTo(b.CreatedAt);
            return c != 0 ? c : a.Seq.CompareTo(b.Seq);
        });
    }

    /// <summary>
    /// Catch-up dopo un reconnect SignalR: gli eventi consegnati mentre eravamo disconnessi
    /// sono persi (SignalR non li replay-a), quindi facciamo una LoadMessages completa appena
    /// torniamo online. Senza questo, una flessione di rete durante un burst di file lascia
    /// il banner fermo finché l'utente non scrive (la UX riportata dall'utente).
    /// </summary>
    private async void OnRealtimeConnectionChanged(ConnectionState state)
    {
        if (state != ConnectionState.Connected) return;
        try
        {
            await InvokeAsync(async () =>
            {
                Console.WriteLine("[echat] SignalR reconnected; full refresh");
                await LoadMessages();
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[echat] OnRealtimeConnectionChanged crashed: {ex}");
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputText)) return;
        _sending = true;
        try
        {
            // In modalità Plain l'input ora è una textarea multi-riga, quindi anche col
            // preventDefault lato JS su Enter trimmiamo gli spazi finali in modo difensivo:
            // un newline vagante potrebbe ancora insinuarsi se una race del browser o una
            // stranezza di focus consegnasse il keydown all'@onkeydown di Blazor dopo che
            // il default nativo l'ha già inserito.
            var text = _format == MessageFormat.Plain ? _inputText.TrimEnd() : _inputText;
            await ChatSdk.SendMessageAsync(ConversationId, text, _format);
            _inputText = "";
            // Pulire il valore via codice non scatena `input`, quindi il listener autogrow
            // non se ne accorge; riportiamo esplicitamente la textarea alla sua altezza minima
            // dopo l'invio.
            try { await JS.InvokeVoidAsync("echatAutogrow.fit", "echat-md-input"); } catch { }
            await LoadMessages();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Send failed: {ex.Message}");
            if (IsKeyAccessError(ex))
                _keyAccessError = KeyAccessErrorText;
            else
            {
                _uploadStatus = $"Send failed: {ex.Message}";
                _ = ClearUploadStatusAfterDelayAsync();
            }
        }
        _sending = false;
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (_sending) return;
        // Plain  Enter invia, Shift+Enter inserisce un newline.
        // Markdown / HTML  Enter inserisce un newline (di solito servono); Ctrl/Cmd+Enter invia.
        if (_format == MessageFormat.Plain)
        {
            if (e.Key == "Enter" && !e.ShiftKey) await SendMessage();
        }
        else
        {
            if (e.Key == "Enter" && (e.CtrlKey || e.MetaKey)) await SendMessage();
        }
    }

    private async Task OnFilePicked(InputFileChangeEventArgs e)
    {
        var files = e.GetMultipleFiles(maximumFileCount: 20);
        if (files.Count == 0) return;

        _sending = true;
        try
        {
            var caption = string.IsNullOrWhiteSpace(_inputText) ? null : _inputText;
            _inputText = "";
            var sent = 0;

            // Pre-riserva i seq di tutti i file in una sola chiamata invece di una per file.
            // I SendFileAsync che seguono prendono i seq dalla memoria, senza altre chiamate.
            try { await ChatSdk.PreReserveSeqsAsync(ConversationId, files.Count); }
            catch (Exception ex) { Console.WriteLine($"[echat] PreReserveSeqsAsync failed: {ex.Message}"); }

            for (int i = 0; i < files.Count; i++)
            {
                var file = files[i];

                if (file.Size > MaxUploadBytes)
                {
                    _uploadStatus = $"Skipped {file.Name} ({file.Size / 1024.0 / 1024.0:F1} MiB > {MaxUploadBytes / 1024 / 1024} MiB cap)";
                    StateHasChanged();
                    continue;
                }

                _uploadStatus = files.Count == 1
                    ? $"Encrypting & uploading {file.Name}…"
                    : $"({i + 1}/{files.Count}) {file.Name}…";
                StateHasChanged();

                try
                {
                    using var stream = file.OpenReadStream(MaxUploadBytes);
                    using var ms = new MemoryStream();
                    await stream.CopyToAsync(ms);

                    // La caption si attacca solo al primo file, così non si ripete sui multi-drop.
                    await ChatSdk.SendFileAsync(
                        ConversationId, ms.ToArray(), file.Name, file.ContentType,
                        sent == 0 ? caption : null);
                    sent++;
                }
                catch (Exception ex)
                {
                    _uploadStatus = $"Upload of {file.Name} failed: {ex.Message}";
                    StateHasChanged();
                }
            }

            _uploadStatus = sent > 0
                ? $"Sent {sent} of {files.Count} file(s)"
                : "No files were sent";
            await LoadMessages();
        }
        finally
        {
            _sending = false;
            StateHasChanged();
            _ = ClearUploadStatusAfterDelayAsync();
        }
    }

    /// <summary>
    /// Auto-pulisce il banner di stato upload dopo 4 s. Fatto come singolo metodo async invece di
    /// `Task.Delay(...).ContinueWith(...)` perché quest'ultimo smista la continuation su thread
    /// diversi sotto WasmEnableThreads, e questo manda in tilt il lock della TimerQueue del runtime.
    /// </summary>
    private async Task ClearUploadStatusAfterDelayAsync()
    {
        var snapshot = _uploadStatus;
        await Task.Delay(4000);
        // Pulisci solo se il banner non è stato sostituito da un messaggio più recente.
        if (!ReferenceEquals(_uploadStatus, snapshot)) return;
        await InvokeAsync(() =>
        {
            _uploadStatus = null;
            StateHasChanged();
        });
    }

