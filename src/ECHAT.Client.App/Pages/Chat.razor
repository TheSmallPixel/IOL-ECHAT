    protected override async Task OnInitializedAsync()
    {
        await SetAuth();

        var authState = await AuthState.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(idClaim, out var uid))
            _myDeviceId = uid;

        await Realtime.ConnectAsync();
        Realtime.OnMessageAvailable += OnNewMessage;
        Realtime.OnMemberChanged += OnMemberChanged;
        Realtime.OnMessageModerated += OnMessageModerated;
        Realtime.OnConversationChanged += OnConversationChanged;
        Realtime.OnConnectionStateChanged += OnRealtimeConnectionChanged;
        MigrationTracker.StateChanged += OnMigrationStateChanged;

        await LoadConversationData();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedConversationId != Guid.Empty && _loadedConversationId != ConversationId)
        {
            await LoadConversationData();
        }
    }

    private bool _dropZoneAttached;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Drop zone: riprova finché attach() non risponde con successo. Protegge dal caso in cui
        // il file input non sia ancora nel DOM al primo render, e da un re-render che sostituisce
        // l'elemento.
        if (!_dropZoneAttached)
        {
            try
            {
                var ok = await JS.InvokeAsync<bool>("echatDropZone.attach", "chat-page", "echat-file-input");
                if (ok) _dropZoneAttached = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[echat] dropZone attach error: {ex.Message}");
            }
        }

        // Autofocus sulla search delle menzioni: parte una volta per apertura. L'<input> di ricerca
        // è condizionale, quindi il suo ElementReference è valido solo dopo il render che lo mostra.
        if (_mentionShouldFocus && _showMentionPicker)
        {
            _mentionShouldFocus = false;
            try { await _mentionSearchRef.FocusAsync(); } catch { }
        }
    }

    private async Task LoadConversationData()
    {
        _loadedConversationId = ConversationId;
        _messages = null;
        _showMembers = false;
        _searchResults = null;
        _searchQuery = "";
        _expandedInfoIds.Clear();

        await LoadConversation();
        await LoadMembersInternal();
        await LoadMessages();
        // Niente JoinConversation: gli eventi SignalR sono indirizzati per utente, non per gruppo.
        // LoadMessages scrolla già in fondo dopo il fetch iniziale.
    }

    private async Task SetAuth()
    {
        var token = await AuthState.GetTokenAsync();
        if (!string.IsNullOrEmpty(token))
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
    }

    private async Task ScrollToBottomIfNeeded()
    {
        try
        {
            // Auto-scroll solo se l'utente è già vicino al fondo; altrimenti lo strapperemmo
            // via dalla cronologia vecchia che stava leggendo.
            var nearBottom = await JS.InvokeAsync<bool>("eval",
                "(function(){var el=document.getElementById('messages-container');" +
                "return !!el && (el.scrollHeight - el.scrollTop - el.clientHeight < 150);})()");
            if (nearBottom)
                await JS.InvokeVoidAsync("echatScroll.toBottom", "messages-container");
        }
        catch { }
    }

    // I membri sono indicizzati per UserId (MemberDto.Id == userId); il mittente di un messaggio è
    // identificato dal suo SenderUserId (NON dal SenderDeviceId fisico, che cambia per device/reset).
    private MemberDto? GetSender(Guid senderUserId)
    {
        _membersMap.TryGetValue(senderUserId, out var member);
        return member;
    }

    // Riconosce gli errori di "questo device non ha la chiave giusta": unwrap CEK fallito (chiave
    // sbagliata) o nessun wrap disponibile per il device. Distinto da errori di rete/altro.
    private static bool IsKeyAccessError(Exception ex)
    {
        var m = ex.Message ?? string.Empty;
        return m.Contains("CEK unwrap failed", StringComparison.OrdinalIgnoreCase)
            || m.Contains("unwrap", StringComparison.OrdinalIgnoreCase)
            || m.Contains("No CEK available", StringComparison.OrdinalIgnoreCase);
    }

